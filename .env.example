# Copy to .env and fill in.

# Server port
PORT=3000

# Where the SQLite database lives (defaults to ./data)
# DATA_DIR=/var/lib/returns-app

# --- Email: pick ONE of the options below. None set = preview mode
# (reports generated and logged, not sent).

# Option 0 (preferred on Railway trial/hobby): Gmail API over HTTPS — no new
# vendor, works where SMTP ports are blocked. Setup (one time, ~15 min):
#   1. console.cloud.google.com → create a project (any name)
#   2. APIs & Services → Library → enable "Gmail API"
#   3. OAuth consent screen → Internal (Workspace) → add scope gmail.send
#   4. Credentials → Create credentials → OAuth client ID → Web application →
#      authorized redirect URI: https://developers.google.com/oauthplayground
#   5. Go to developers.google.com/oauthplayground → gear icon → "Use your own
#      OAuth credentials" → paste client ID + secret → in Step 1 enter scope
#      https://www.googleapis.com/auth/gmail.send → Authorize (log in as the
#      sending account) → Step 2 "Exchange authorization code for tokens" →
#      copy the Refresh token
# GMAIL_CLIENT_ID=xxxx.apps.googleusercontent.com
# GMAIL_CLIENT_SECRET=GOCSPX-xxxx
# GMAIL_REFRESH_TOKEN=1//xxxx
# EMAIL_FROM=jeff@dotprinter.com

# Option A: Resend HTTPS API (https://resend.com) — required on hosts that block
# SMTP ports, e.g. Railway trial/hobby plans. Free tier: 100 emails/day.
# EMAIL_FROM must be on a domain you verified in Resend (or use onboarding@resend.dev
# for testing, which can only send to your own Resend account email).
# RESEND_API_KEY=re_xxxxxxxxxxxx
# EMAIL_FROM=returns@yourdomain.com

# Option B: Gmail SMTP — create an App Password at
# https://myaccount.google.com/apppasswords (requires 2-step verification).
# Does NOT work on Railway trial/hobby plans (SMTP ports blocked; Pro only).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=returns@yourdomain.com
SMTP_PASS=your-16-char-app-password
