# Copy to .env and fill in.

# Server port
PORT=3000

# Where the SQLite database lives (defaults to ./data)
# DATA_DIR=/var/lib/returns-app

# Gmail SMTP — create an App Password at https://myaccount.google.com/apppasswords
# (requires 2-step verification on the account). Leave blank to run in preview mode:
# reports are generated and logged but not sent.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=returns@yourdomain.com
SMTP_PASS=your-16-char-app-password
